  "keyFeatures": [
    "Parametric drought insurance with automated claim processing",
    "Chainlink CRE workflow for off-chain weather data monitoring",
    "Smart contracts on Base Sepolia for instant payouts",
    "Wallet integration via Coinbase OnchainKit",
    "10x coverage payout when rainfall drops below threshold",
    "Median aggregation for reliable weather data"
  ],
  "publicApiSurface": [
    "purchasePolicy(lat, long) - Purchase drought insurance policy",
    "executePayout(policyId) - Trigger payout for drought condition",
    "setCREAddress(address) - Set authorized CRE runtime address",
    "policies(policyId) - View policy details",
    "activePolicyIds(index) - Get active policy IDs",
    "CronCapability.trigger() - Schedule workflow execution",
    "HTTPClient.sendRequest() - Fetch weather data",
    "EVMClient.callContract() - Read contract state",
    "EVMClient.report() - Execute contract transaction"
  ]
